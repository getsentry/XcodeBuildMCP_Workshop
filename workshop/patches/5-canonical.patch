 import SwiftUI
 
 @main
@@ -13,6 +14,21 @@ struct WeatherApp: App {
     private let weatherService: WeatherService
 
     init() {
+        let options = Options()
+        options.dsn = "https://cd90afa825f312071330f26be7b56b7a@o4509446862274560.ingest.us.sentry.io/4511354463846400"
+        options.tracesSampleRate = 1.0
+        options.sessionReplay.sessionSampleRate = 0.1
+        options.sessionReplay.onErrorSampleRate = 1.0
+        options.enableLogs = true
+        options.enableAutoPerformanceTracing = true
+        options.tracePropagationTargets = ["localhost"]
+        options.enableNetworkTracking = true
+        options.enableSwizzling = true
+        #if DEBUG
+        options.debug = true
+        #endif
+        SentrySDK.start(options: options)
+
         let useMock = ProcessInfo.processInfo.arguments.contains("--mock-weather-api")
         weatherService = AppWeatherServiceFactory.makeService()
         AppLog.app.notice("launch service=\(useMock ? "mock" : "production", privacy: .public)")
