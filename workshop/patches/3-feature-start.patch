 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/app/Weather/Models/WeatherModels.swift b/app/Weather/Models/WeatherModels.swift
index 560c298..cac1272 100644
--- a/app/Weather/Models/WeatherModels.swift
+++ b/app/Weather/Models/WeatherModels.swift
@@ -204,6 +204,6 @@ struct WeatherUnits: Equatable, Sendable {
     var pressure: PressureUnit = .millibars
     var distance: DistanceUnit = .miles
     var animationsEnabled = true
-    var alertsEnabled = true
+    var alertsEnabled = true   // TODO: not yet wired into UI
     var reduceTransparency = false
 }
